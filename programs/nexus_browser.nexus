/* NEXUS_EXECUTABLE | ID: nexus_nav | Title: Nexus Navigator | Width: 600px | Height: 450px */

const container = NexusAPI.getContainer();
// URL del proxy público (puedes usar el tuyo si luego lo montas)
const PROXY_URL = "https://cors-anywhere.herokuapp.com/"; 

container.innerHTML = `
    <div style="display: flex; flex-direction: column; height: 100%; background: #c0c0c0; font-family: 'Segoe UI', Tahoma, sans-serif;">
        <div style="padding: 5px; background: #d4d0c8; border-bottom: 2px solid #808080; display: flex; gap: 5px; align-items: center;">
            <input type="text" id="nav-url" value="https://www.google.com" 
                   style="flex-grow: 1; font-size: 11px; padding: 3px; border: 2px inset #fff; background: #fff; color: #000;">
            <button id="nav-go" style="padding: 2px 8px; font-size: 10px; font-weight: bold; cursor: pointer;">GO</button>
        </div>
        <div id="frame-container" style="flex-grow: 1; background: #fff; position: relative;">
            <iframe id="nav-frame" src="" 
                    style="width: 100%; height: 100%; border: none;"></iframe>
        </div>
    </div>
`;

const frame = container.querySelector('#nav-frame');
const input = container.querySelector('#nav-url');
const goBtn = container.querySelector('#nav-go');

const navigate = async () => {
    let url = input.value.trim();
    if (!url.startsWith('http')) url = 'https://' + url;

    try {
        // 1. Usamos fetch donde SÍ podemos meter los headers que pide el proxy
        const response = await fetch(PROXY_URL + url, {
            headers: {
                'X-Requested-With': 'XMLHttpRequest' // Esto desbloquea CORS Anywhere
            }
        });

        const html = await response.text();

        // 2. Inyectamos el HTML directamente en el documento del iframe
        const doc = frame.contentDocument || frame.contentWindow.document;
        doc.open();
        doc.write(html);
        doc.close();

        // 3. (Opcional) Intentar arreglar las rutas relativas (imágenes/CSS)
        const baseTag = doc.createElement('base');
        baseTag.href = url;
        doc.head.appendChild(baseTag);

    } catch (err) {
        console.error("Nexus Nav Error:", err);
        // Aquí podrías mostrar un error visual en tu container
    }
};

goBtn.onclick = navigate;
input.onkeydown = (e) => { if (e.key === 'Enter') navigate(); };
